DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false

# Required for local adapters like codex_local / claude_local / cursor.
# The server uses this to mint short-lived agent auth tokens that are injected
# into local agent runs as PAPERCLIP_API_KEY for status, checkout, and comment writes.
# PAPERCLIP_AGENT_JWT_SECRET=replace-with-a-long-random-string

# Optional: keep embedded-postgres backups outside ~/.paperclip/instances/default
# if you want them to survive an instance reset or DB directory cleanup.
# PAPERCLIP_DB_BACKUP_ENABLED=true
# PAPERCLIP_DB_BACKUP_INTERVAL_MINUTES=15
# PAPERCLIP_DB_BACKUP_RETENTION_DAYS=30
# PAPERCLIP_DB_BACKUP_DIR=~/paperclip-db-backups
# Windows example:
# PAPERCLIP_DB_BACKUP_DIR=C:/Users/<you>/OneDrive/paperclip-db-backups
